{
  "name": "pendidikanmaster",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "infra:up": "docker compose -f infra/docker-compose.yml --env-file .env up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml --env-file .env down",
    "infra:logs": "docker compose -f infra/docker-compose.yml --env-file .env logs -f",
    "infra:status": "docker compose -f infra/docker-compose.yml --env-file .env ps"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.8.0"
}

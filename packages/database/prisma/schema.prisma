generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  domain      String?  @unique
  logoUrl     String?
  isActive    Boolean  @default(true)
  planType    PlanType @default(FREE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  settings    TenantSetting?

  @@map("tenants")
}

model TenantSetting {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String          @unique @db.Uuid
  institutionType InstitutionType @default(SCHOOL_SD)
  primaryColor    String          @default("#6C63D8")
  address         String?
  phone           String?
  email           String?
  website         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  email        String
  phone        String?
  passwordHash String?
  fullName     String
  avatarUrl    String?
  role         UserRole  @default(STUDENT)
  isActive     Boolean   @default(true)
  isVerified   Boolean   @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile      UserProfile?
  sessions     Session[]
  auditLogs    AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([email])
  @@map("users")
}

model UserProfile {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @unique @db.Uuid
  tenantId   String    @db.Uuid
  nik        String?
  nisn       String?
  nuptk      String?
  nidn       String?
  nim        String?
  birthDate  DateTime?
  birthPlace String?
  gender     Gender?
  address    String?
  city       String?
  province   String?
  postalCode String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("user_profiles")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  tenantId     String   @db.Uuid
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String?  @db.Uuid
  action    String
  entity    String?
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, action])
  @@index([tenantId, entity])
  @@index([createdAt])
  @@map("audit_logs")
}

enum PlanType {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum InstitutionType {
  SCHOOL_SD
  SCHOOL_SMP
  SCHOOL_SMA
  SCHOOL_SMK
  COLLEGE
  POLYTECHNIC
  ACADEMY
  INSTITUTE
  UNIVERSITY
}

enum UserRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  RECTOR
  VICE_RECTOR
  DEAN
  VICE_DEAN
  DEPARTMENT_HEAD
  LECTURER
  STUDENT_COLLEGE
  PRINCIPAL
  VICE_PRINCIPAL
  TEACHER
  HOMEROOM_TEACHER
  STUDENT
  OPERATOR
  TREASURER
  STAFF
  PARENT
  ALUMNI
  APPLICANT
}

enum Gender {
  MALE
  FEMALE
}

// ═══════════════════════════════════════════════════════════
// SPMB / PPDB — Penerimaan Peserta Didik/Mahasiswa Baru
// ═══════════════════════════════════════════════════════════

model SpmbPeriod {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  name        String                      // contoh: "PPDB 2026/2027"
  academicYear String                     // contoh: "2026/2027"
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paths       SpmbPath[]
  applicants  SpmbApplicant[]

  @@index([tenantId])
  @@map("spmb_periods")
}

model SpmbPath {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  periodId    String   @db.Uuid
  name        String                      // Reguler, Prestasi, Beasiswa, Undangan
  description String?
  quota       Int      @default(0)
  registrationFee Decimal @default(0) @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  period      SpmbPeriod      @relation(fields: [periodId], references: [id], onDelete: Cascade)
  applicants  SpmbApplicant[]

  @@index([tenantId])
  @@index([periodId])
  @@map("spmb_paths")
}

model SpmbApplicant {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  periodId        String   @db.Uuid
  pathId          String   @db.Uuid
  registrationNo  String                   // nomor pendaftaran otomatis
  fullName        String
  email           String
  phone           String
  nik             String?
  birthPlace      String?
  birthDate       DateTime?
  gender          Gender?
  address         String?
  parentName      String?
  parentPhone     String?
  previousSchool  String?                  // asal sekolah/institusi
  major           String?                  // pilihan jurusan/prodi
  status          SpmbStatus @default(REGISTERED)
  registeredAt    DateTime @default(now())
  updatedAt       DateTime @updatedAt

  period          SpmbPeriod        @relation(fields: [periodId], references: [id], onDelete: Cascade)
  path            SpmbPath          @relation(fields: [pathId], references: [id], onDelete: Cascade)
  documents       SpmbDocument[]
  payments        SpmbPayment[]
  result          SpmbResult?

  @@unique([tenantId, registrationNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([periodId])
  @@map("spmb_applicants")
}

model SpmbDocument {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicantId  String   @db.Uuid
  tenantId     String   @db.Uuid
  type         String                      // KTP, KK, Ijazah, Rapor, Akta Lahir, Foto
  fileKey      String                      // key MinIO
  fileUrl      String
  isVerified   Boolean  @default(false)
  verifiedAt   DateTime?
  notes        String?
  uploadedAt   DateTime @default(now())

  applicant    SpmbApplicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([applicantId])
  @@map("spmb_documents")
}

model SpmbPayment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicantId   String   @db.Uuid
  tenantId      String   @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  status        PaymentStatus @default(PENDING)
  method        String?                    // VA, QRIS, Transfer
  externalRef   String?                    // ID dari payment gateway
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  applicant     SpmbApplicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([applicantId])
  @@map("spmb_payments")
}

model SpmbResult {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicantId   String   @unique @db.Uuid
  tenantId      String   @db.Uuid
  status        SpmbResultStatus
  score         Decimal? @db.Decimal(6, 2)
  notes         String?
  announcedAt   DateTime?
  reregisteredAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  applicant     SpmbApplicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("spmb_results")
}

enum SpmbStatus {
  REGISTERED      // Baru daftar
  DOCUMENT_CHECK  // Verifikasi dokumen
  PAYMENT_PENDING // Menunggu pembayaran
  PAID            // Sudah bayar
  SELECTION       // Proses seleksi
  COMPLETED       // Selesai (hasil sudah keluar)
}

enum SpmbResultStatus {
  LULUS
  CADANGAN
  TIDAK_LULUS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}